    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "commitlint": "^19.8.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3"
  },
  "packageManager": "pnpm@11.5.2"
}
