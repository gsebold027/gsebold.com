{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": false,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": false,
    "typeRoots": ["./node_modules/@types", "./@types"]
  },
  "include": ["src/**/*", "@types/**/*"],
  "exclude": ["node_modules", "dist"]
}
